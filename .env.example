# Project Bourne — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
#
# docker compose reads .env automatically from the repo root.
# In production, all values come from AWS Secrets Manager.

# ─── Google OAuth2 ───────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set the authorized redirect URI to: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── JWT Signing Keys (RS256) ────────────────────────────────────────────────
# Base64-encoded DER format (no PEM headers). Generate a keypair with:
#
#   openssl genrsa -out private.pem 2048
#   openssl pkcs8 -topk8 -inform PEM -outform DER -in private.pem -nocrypt | base64 -w 0
#   openssl rsa -in private.pem -pubout -outform DER | base64 -w 0
#
# Paste the first output as JWT_PRIVATE_KEY and the second as JWT_PUBLIC_KEY.
# Delete private.pem when done — never commit it.
# See: planning/adr/coding/ADR-C003-jwt-signing-algorithm.md
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRATION_SECONDS=86400

# ─── Anthropic API ───────────────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Frontend URL ────────────────────────────────────────────────────────────
# Where users are redirected after OAuth2 login completes.
# Default works for local dev (docker compose maps frontend to localhost:3000).
# Override in staging/production with the real public URL.
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# docker compose hardcodes these for the containerized stack — only needed
# when running the backend directly (e.g. from IntelliJ).
# DB_URL=jdbc:postgresql://localhost:5432/projectbourne
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
# Same as above — only needed when running the backend outside of docker compose.
# REDIS_HOST=localhost
# REDIS_PORT=6379
