# Copy this file to .env and fill in values. Never commit .env.

# Google OAuth2 (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT signing keys — RS256 key pair (see planning/adr/coding/ADR-C003-jwt-signing-algorithm.md)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=
